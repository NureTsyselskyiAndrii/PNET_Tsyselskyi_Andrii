@page "/goods"
@rendermode InteractiveServer
@inject IGoodService GoodSvc
@inject ILogger<Goods> Logger
@using ShopApp.Models
@using ShopApp.Services

<PageTitle>Товари</PageTitle>
<h3><i class="bi bi-box-seam me-2 text-success"></i>Товари</h3>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<button class="btn btn-success mb-3" @onclick="OpenCreate">
    <i class="bi bi-plus-circle me-1"></i>Додати товар
</button>

@if (_goods is null)
{
    <p><em>Завантаження…</em></p>
}
else
{
    <table class="table table-striped table-hover align-middle small">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Назва</th>
                <th>Ціна</th>
                <th>К-ть</th>
                <th>Виробник</th>
                <th>Відділ</th>
                <th>Опис</th>
                <th style="width:120px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var g in _goods)
            {
                <tr>
                    <td>@g.GoodId</td>
                    <td>@g.Name</td>
                    <td>@g.Price?.ToString("N2") ₴</td>
                    <td>@g.Quantity</td>
                    <td>@g.Producer</td>
                    <td>@(g.Department?.Name ?? "—")</td>
                    <td>@g.Description</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => OpenEdit(g)">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(g)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_showForm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Редагувати" : "Новий") товар</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="_form" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Назва *</label>
                                <InputText class="form-control" @bind-Value="_form.Name" />
                                <ValidationMessage For="() => _form.Name" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Ціна *</label>
                                <InputNumber class="form-control" @bind-Value="_form.Price" />
                                <ValidationMessage For="() => _form.Price" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Кількість</label>
                                <InputNumber class="form-control" @bind-Value="_form.Quantity" />
                                <ValidationMessage For="() => _form.Quantity" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Виробник</label>
                                <InputText class="form-control" @bind-Value="_form.Producer" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Відділ</label>
                                <InputSelect class="form-select" @bind-Value="_form.DeptId">
                                    <option value="">— без відділу —</option>
                                    @foreach (var d in _depts)
                                    {
                                        <option value="@d.DeptId">@d.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Опис</label>
                                <InputText class="form-control" @bind-Value="_form.Description" />
                            </div>
                        </div>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-success me-2">
                                <i class="bi bi-check2 me-1"></i>Зберегти
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="CloseForm">Скасувати</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (_deleteTarget is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Видалити товар?</h5>
                </div>
                <div class="modal-body">Видалити <strong>@_deleteTarget.Name</strong>?</div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="DeleteConfirmedAsync">Так, видалити</button>
                    <button class="btn btn-secondary" @onclick="() => _deleteTarget = null">Скасувати</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<Good>? _goods;
    List<Department> _depts = new();
    Good _form = new();
    Good? _deleteTarget;
    bool _showForm, _isEdit;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Goods page loaded");
        await LoadAsync();
        _depts = await GoodSvc.GetDepartmentsAsync();
    }

    async Task LoadAsync()
    {
        try { _goods = await GoodSvc.GetAllAsync(); }
        catch (Exception ex) { _error = ex.Message; }
    }

    void OpenCreate() { _form = new(); _isEdit = false; _showForm = true; }

    void OpenEdit(Good g)
    {
        _form = new Good
        {
            GoodId = g.GoodId,
            Name = g.Name,
            Price = g.Price,
            Quantity = g.Quantity,
            Producer = g.Producer,
            DeptId = g.DeptId,
            Description = g.Description
        };
        _isEdit = true; _showForm = true;
    }

    void CloseForm() => _showForm = false;
    void ConfirmDelete(Good g) => _deleteTarget = g;

    async Task SaveAsync()
    {
        try
        {
            if (_isEdit) await GoodSvc.UpdateAsync(_form);
            else await GoodSvc.CreateAsync(_form);
            CloseForm();
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    async Task DeleteConfirmedAsync()
    {
        try
        {
            await GoodSvc.DeleteAsync(_deleteTarget!.GoodId);
            _deleteTarget = null;
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
